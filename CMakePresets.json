{
  "version": 3,
  "configurePresets": [
    {
      "name": "xcode-debug",
      "displayName": "Xcode — Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/xcode",
      "cacheVariables": {
        "SCRIVI_BUILD_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "xcode-release",
      "displayName": "Xcode — Release",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/xcode-release",
      "cacheVariables": {
        "SCRIVI_BUILD_TESTS": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja — Debug (CI / terminal)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja",
      "cacheVariables": {
        "SCRIVI_BUILD_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "xcode-debug",
      "configurePreset": "xcode-debug",
      "configuration": "Debug"
    },
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug"
    }
  ],
  "testPresets": [
    {
      "name": "xcode-debug",
      "configurePreset": "xcode-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
